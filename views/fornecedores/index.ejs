<!DOCTYPE html>
<html>
<head>
    <title>Fornecedores</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <%- include('../partials/nav') %>

    <div class="container mt-4">

        <!-- FORMULÁRIO -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <h5 class="mb-3">
                    <%= fornecedorEditar ? '✏️ Editar' : '➕ Novo' %> Fornecedor
                </h5>

                <form 
                    action="<%= fornecedorEditar 
                        ? '/fornecedores/editar/' + fornecedorEditar.id 
                        : '/fornecedores/salvar' %>" 
                    method="POST"
                >

                    <div class="mb-3">
                        <label class="form-label">Nome</label>

                        <input 
                            type="text" 
                            name="nome" 
                            class="form-control form-control-lg" 
                            required
                            value="<%= fornecedorEditar ? fornecedorEditar.nome : '' %>"
                        >
                    </div>

                    <div class="d-grid">

                        <button class="btn btn-<%= fornecedorEditar ? 'success' : 'primary' %>">
                            <%= fornecedorEditar ? 'Atualizar' : 'Salvar' %>
                        </button>

                        <!-- CORRIGIDO AQUI -->
                        <% if(fornecedorEditar){ %>

                            <a href="/fornecedores" class="btn btn-secondary mt-2">
                                Cancelar
                            </a>

                        <% } %>

                    </div>

                </form>

            </div>
        </div>

        <!-- LISTAGEM -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">📂 Fornecedores</h4>
        </div>

        <!-- DESKTOP -->
        <div class="d-none d-md-block">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th width="120">Ações</th>
                    </tr>
                </thead>

                <tbody>

                    <% fornecedores.forEach(fornecedor => { %>

                        <tr>

                            <td><%= fornecedor.id %></td>

                            <td><%= fornecedor.nome %></td>

                            <td>

                                <a 
                                    href="/fornecedores/editar/<%= fornecedor.id %>" 
                                    class="btn btn-warning btn-sm"
                                >
                                    ✏️
                                </a>

                                <a 
                                    href="/fornecedores/excluir/<%= fornecedor.id %>" 
                                    class="btn btn-danger btn-sm"
                                    onclick="return confirm('Deseja excluir este fornecedor?')"
                                >
                                    🗑️
                                </a>

                            </td>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

        <!-- MOBILE -->
        <div class="d-md-none">

            <% fornecedores.forEach(fornecedor => { %>

                <div class="card mb-3 shadow-sm">

                    <div class="card-body">

                        <h5 class="card-title">
                            <%= fornecedor.nome %>
                        </h5>

                        <p class="card-text text-muted">
                            ID: <%= fornecedor.id %>
                        </p>

                        <div class="d-grid gap-2">

                            <a 
                                href="/fornecedores/editar/<%= fornecedor.id %>" 
                                class="btn btn-warning btn-sm"
                            >
                                ✏️ Editar
                            </a>

                            <a 
                                href="/fornecedores/excluir/<%= fornecedor.id %>" 
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Deseja excluir este fornecedor?')"
                            >
                                ❌ Excluir
                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

        <a href="/" class="btn btn-secondary w-100 mt-3">
            Voltar
        </a>

    </div>

    <%- include('../partials/footer') %>

</body>
</html>